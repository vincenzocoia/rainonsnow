Package: rainonsnow
Type: Package
Title: Functions for the rain-on-snow research project
Version: 0.1.0
Authors@R: c(
    person(
      "Vincenzo", "Coia",
      email = "vincenzo.coia@gmail.com",
      role = c("aut", "cre", "cph")
    )
